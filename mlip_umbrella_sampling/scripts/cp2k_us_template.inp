#
# CP2K + PLUMED Umbrella Sampling template (W2 paper #1, US apples-to-apples)
#
# IDENTICAL system parameters как W2 metad v2 (cell, basis, DFT, thermostat).
# ONLY difference: USE_PLUMED .TRUE. + plumed.dat read для restraint.
#
# Per-window deployment:
#   1. Copy this file → /workspace/window_NN/cp2k_us.inp (no edits to .inp needed!)
#   2. Copy infra/us_protocol/windows/window_NN/plumed.dat → /workspace/window_NN/plumed.dat
#   3. Copy structure.xyz, RESTART.wfn, BASIS_MOLOPT, GTH_POTENTIALS
#   4. Launch: cp2k_wrapper.sh cp2k_us.inp <ranks> <omp> <steps> cp2k_us
#
# CP2K reads `plumed.dat` ОТТУДА где runs the executable (PWD).

&GLOBAL
  PROJECT cp2k_us
  RUN_TYPE MD
  PRINT_LEVEL LOW
  WALLTIME -1
  PREFERRED_DIAG_LIBRARY SCALAPACK
  ! s169 consilium B2 fix: &FM SCALAPACK required for MPI>1 (COSMA SIGSEGV F-053/F-057). Was MISSING -- carrier_B had it, this template did not.
  &FM
    TYPE_OF_MATRIX_MULTIPLICATION SCALAPACK
  &END FM
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    POTENTIAL_FILE_NAME GTH_POTENTIALS
    CHARGE 1
    ! WFN_RESTART_FILE_NAME ./cp2k_us-RESTART.wfn  ! disabled — fresh deploy, ATOMIC guess; no silent fallback risk (chemist QA s138 Patch 5)

    &QS
      EPS_DEFAULT 1.0E-12
      ! s138 evening physicist Patch P2: ASPC ORDER 3 caused segfault wfi_extrapolate.F:1141 в old image (Spack relocate fail).
      ! New image (s138 night, fresh master git clone) likely fixes — TEST ASPC FIRST на smoke 100 steps.
      ! If ASPC works → keep (5-8× faster than USE_GUESS для metallic systems).
      ! If segfault repeats → fall back ORDER 1 → finally USE_GUESS.
      EXTRAPOLATION ASPC
      EXTRAPOLATION_ORDER 3              ! TEST FIRST на smoke; fallback ladder: ORDER 3 → ORDER 1 → USE_GUESS
    &END QS

    &MGRID
      CUTOFF 320
      REL_CUTOFF 40
      NGRIDS 4
    &END MGRID

    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
      &VDW_POTENTIAL
        POTENTIAL_TYPE PAIR_POTENTIAL
        &PAIR_POTENTIAL
          TYPE DFTD3(BJ)
          REFERENCE_FUNCTIONAL PBE
        &END PAIR_POTENTIAL
      &END VDW_POTENTIAL
    &END XC

    &SCF
      SCF_GUESS ATOMIC                  ! fresh deploy uses ATOMIC; restart wfn disabled per chemist QA s138 Patch 5
      MAX_SCF 500
      EPS_SCF 1.0E-5
      ADDED_MOS 200                     ! was 100; physicist QA s138 Patch 2 — 41% margin too tight для charged + FERMI 500K (kT_e tail 0.21 eV)
      &DIAGONALIZATION
        ALGORITHM STANDARD
      &END DIAGONALIZATION
      &MIXING
        METHOD BROYDEN_MIXING
        ALPHA 0.2
        NBROYDEN 8
      &END MIXING
      &SMEAR
        METHOD FERMI_DIRAC
        ELECTRONIC_TEMPERATURE [K] 500.0
      &END SMEAR
      &OUTER_SCF
        EPS_SCF 1.0E-5
        MAX_SCF 10
      &END OUTER_SCF
    &END SCF

    &POISSON
      PERIODIC XYZ
    &END POISSON
  &END DFT

  &SUBSYS
    &CELL
      A     11.022000   0.000000   0.000000
      B      0.000000  11.022000   0.000000
      C      0.000000   0.000000   6.500000
      PERIODIC XYZ
    &END CELL

    &TOPOLOGY
      COORD_FILE_NAME structure.xyz
      COORD_FILE_FORMAT XYZ
    &END TOPOLOGY

    &KIND Fe
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q16
    &END KIND
    &KIND S
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q6
    &END KIND
    &KIND O
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q6
    &END KIND
    &KIND H
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q1
    &END KIND
  &END SUBSYS
&END FORCE_EVAL

&MOTION
  &MD
    ! NB: для apples-to-apples с MLIP US используем LANGEVIN (γ=0.01 fs⁻¹ matches ASE Langevin).
    ! Если хотим NOSE matched к W2 v2 (TIMECON=500 fs) — uncomment NOSE block, comment LANGEVIN.
    ENSEMBLE LANGEVIN
    STEPS 18000                        ! 9 ps prod (1 ps eq + 8 ps prod) — apples-to-apples с MLIP US s136; chemist+physicist QA s138 Patch 1 (5 ps было слишком коротко: N_eff=6-7 per half block, trivial split-halves convergence)
    TIMESTEP [fs] 0.5
    TEMPERATURE [K] 300.0
    &LANGEVIN
      ! γ inverse fs ≈ 0.01 fs⁻¹ matches ASE Langevin friction в MLIP US
      ! CP2K синтаксис: GAMMA в 1/fs
      GAMMA 0.01
    &END LANGEVIN
    ! &THERMOSTAT  ! commented — using LANGEVIN ensemble instead
    !   TYPE NOSE
    !   REGION GLOBAL
    !   &NOSE
    !     LENGTH 3
    !     TIMECON [fs] 500.0
    !     MTS 2
    !   &END NOSE
    ! &END THERMOSTAT
  &END MD

  &FREE_ENERGY
    METHOD METADYN
    &METADYN
      USE_PLUMED .TRUE.                ! READ plumed.dat from PWD — KEY DIFF vs WT-MetaD
      PLUMED_INPUT_FILE plumed.dat
    &END METADYN
  &END FREE_ENERGY

  &PRINT
    &TRAJECTORY
      &EACH
        MD 10                          ! save every 10 steps = 5 fs
      &END EACH
      FORMAT XYZ
    &END TRAJECTORY
    &VELOCITIES
      &EACH
        MD 100
      &END EACH
    &END VELOCITIES
    &RESTART
      &EACH
        MD 100
      &END EACH
      BACKUP_COPIES 2
    &END RESTART
    ! s138 evening physicist Patch P5: Mulliken charges per Fe — detect Fe(II)↔Fe(III) charge transfer mid-trajectory (PBE collapse risk on charged metallic).
    &MULLIKEN
      &EACH
        MD 100
      &END EACH
    &END MULLIKEN
  &END PRINT
&END MOTION

! s138 evening chemist Patch 1: EXT_RESTART block — production safety для Vast.ai SIGTERM/SIGKILL (10 sec window).
! On fresh deploy: RESTART_DEFAULT .FALSE. (no prior restart). On restart cycle: flip к .TRUE. and rename current cp2k_us-1.restart → cp2k_us.restart_in
&EXT_RESTART
  RESTART_FILE_NAME ./cp2k_us-1.restart
  RESTART_DEFAULT .FALSE.
&END EXT_RESTART
