# Variant-A PLUMED smooth-min(d_FeH) restraint -- carrier-probe (600 steps, MOVINGRESTRAINT ramp) @ AT=2.40 A
# CV+restraint defined in plumed_smin.dat (PLUMED CUSTOM log-sum-exp, beta=10/A). NO CP2K &COLVAR/&CONSTRAINT.
# Goal: confirm PLUMED loads on this image (s139 hook risk), smin~1.54 at frame0, restraint applies, no crash.
# COSMA-fix: &GLOBAL FM+PREFERRED_DIAG SCALAPACK (F-053/F-057). Comments on own lines only (F-046).
&GLOBAL
  PROJECT carrier_B
  RUN_TYPE MD
  PRINT_LEVEL LOW
  WALLTIME -1
  PREFERRED_DIAG_LIBRARY SCALAPACK
  &FM
    TYPE_OF_MATRIX_MULTIPLICATION SCALAPACK
  &END FM
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    POTENTIAL_FILE_NAME GTH_POTENTIALS
    CHARGE 1
    &QS
      EPS_DEFAULT 1.0E-12
      EXTRAPOLATION ASPC
      EXTRAPOLATION_ORDER 3
    &END QS
    &MGRID
      CUTOFF 600
      REL_CUTOFF 60
      NGRIDS 4
    &END MGRID
    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
      &VDW_POTENTIAL
        POTENTIAL_TYPE PAIR_POTENTIAL
        &PAIR_POTENTIAL
          TYPE DFTD3(BJ)
          REFERENCE_FUNCTIONAL PBE
        &END PAIR_POTENTIAL
      &END VDW_POTENTIAL
    &END XC
    &SCF
      SCF_GUESS ATOMIC
      MAX_SCF 300
      EPS_SCF 1.0E-5
      ADDED_MOS 64
      &DIAGONALIZATION
        ALGORITHM STANDARD
      &END DIAGONALIZATION
      &MIXING
        METHOD BROYDEN_MIXING
        ALPHA 0.2
        NBROYDEN 8
      &END MIXING
      &SMEAR
        METHOD FERMI_DIRAC
        ELECTRONIC_TEMPERATURE [K] 500
      &END SMEAR
      &OUTER_SCF
        EPS_SCF 1.0E-5
        MAX_SCF 10
      &END OUTER_SCF
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      A  11.022  0.000  0.000
      B   0.000 11.022  0.000
      C   0.000  0.000  6.500
      PERIODIC XYZ
    &END CELL
    &TOPOLOGY
      COORD_FILE_NAME w2_frame0.xyz
      COORD_FILE_FORMAT XYZ
    &END TOPOLOGY
    &KIND Fe
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q16
    &END KIND
    &KIND S
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q6
    &END KIND
    &KIND O
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q6
    &END KIND
    &KIND H
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q1
    &END KIND
  &END SUBSYS
&END FORCE_EVAL

&MOTION
  &MD
    ENSEMBLE NVT
    STEPS 1300
    TIMESTEP [fs] 0.5
    TEMPERATURE [K] 300.0
    &THERMOSTAT
      TYPE NOSE
      REGION GLOBAL
      &NOSE
        LENGTH 3
        TIMECON [fs] 100.0
        MTS 2
      &END NOSE
    &END THERMOSTAT
  &END MD
  &FREE_ENERGY
    METHOD METADYN
    &METADYN
      USE_PLUMED .TRUE.
      PLUMED_INPUT_FILE ./plumed_carrier_B.dat
    &END METADYN
  &END FREE_ENERGY
  &PRINT
    &TRAJECTORY
      &EACH
        MD 2
      &END EACH
      FORMAT XYZ
    &END TRAJECTORY
  &END PRINT
&END MOTION
